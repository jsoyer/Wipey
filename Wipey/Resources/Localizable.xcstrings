    "permission.alert.message" : {
      "comment" : "Alert message explaining why accessibility is needed",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Wipey needs Accessibility permission to lock your keyboard and trackpad." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Wipey a besoin d'accès à l'accessibilité pour verrouiller votre clavier et trackpad." } }
      }
    },
    "permission.alert.open_settings" : {
      "comment" : "Button to open System Settings",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open System Settings" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ouvrir les Réglages Système" } }
      }
    },
    "permission.alert.title" : {
      "comment" : "Alert title when accessibility permission is denied during session start",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Accessibility Permission Required" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Permission d'accessibilité requise" } }
      }
    },
    "permission.body" : {
      "comment" : "Explanation of why Accessibility permission is needed",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Wipey needs Accessibility permission to lock your keyboard and trackpad while you clean your Mac.\n\nYour keystrokes are never stored or transmitted." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Wipey a besoin d'accès à l'accessibilité pour verrouiller votre clavier et trackpad pendant le nettoyage.\n\nVos frappes ne sont jamais enregistrées ni transmises." } }
      }
    },
    "permission.cta" : {
      "comment" : "Button to open System Settings for Accessibility permission",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open System Settings" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ouvrir les Réglages Système" } }
      }
    },
    "permission.instructions" : {
      "comment" : "Step-by-step instructions after opening System Settings",
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Go to Privacy & Security → Accessibility, then enable Wipey." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Allez dans Confidentialité et sécurité → Accessibilité, puis activez Wipey." } }
