    "permission.alert.message" : {
      "comment" : "Alert message explaining why accessibility is needed",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wipey needs Accessibility permission to lock your keyboard and trackpad during cleaning. Please enable it in System Settings."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wipey a besoin de l'autorisation Accessibilité pour verrouiller votre clavier et trackpad pendant le nettoyage. Veuillez l'activer dans les Réglages Système."
          }
        }
      }
    },
